{
    "compilerOptions": {
		"baseUrl": "./",
		"paths": {

			"@src/*": ["src/*"],
			"@IoC/*": ["src/IoC/*"],
			"@infra/*": ["src/infra/*"],
			"@core/*": ["src/core/*"],
			"@entities/*": ["src/core/entities/*"],
			"@models/*": ["src/core/models/*"]

		},
        "module": "NodeNext",
        "target": "ES2022",
        "lib": ["ES2022"],
        "sourceMap": true,
        "rootDir": "src",
        "outDir": "out",
        "strict": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "moduleResolution": "NodeNext"
    },
    "exclude": ["node_modules", ".vscode-test"]
}